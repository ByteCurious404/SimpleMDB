# Movies API - REST Client file
@baseUrl = http://localhost:8080
@api = {{baseUrl}}/api/v1/movies

###

# List movies - page 1
# Send request
GET {{api}}?page=1&size=10
Accept: application/json

###

# List movies - page 2
# Send request
GET {{api}}?page=2&size=8
Accept: application/json

###

# Get one movie
# Send request
GET {{api}}/1
Accept: application/json

###

# Get movie that probably doesn't exist
# Send request
GET {{api}}/9999
Accept: application/json

###

# Create a new movie
# Send request
POST {{api}}
Content-Type: application/json

{
  "title": "Dune: Part Two",
  "year": 2024,
  "description": "Paul Atreides unites with Chani and the Fremen while visions of war haunt his mind."
}

###

# Create another movie (minimal)
# Send request
POST {{api}}
Content-Type: application/json

{
  "title": "The Batman Part II",
  "year": 2026
}

###

# Update movie (full body)
# Send request
PUT {{api}}/1
Content-Type: application/json

{
  "title": "Inception - 15th Anniversary",
  "year": 2010,
  "description": "A thief who steals corporate secrets through the use of dream-sharing technology..."
}

###

# Update only some fields
# Send request
PUT {{api}}/2
Content-Type: application/json

{
  "description": "Updated description - now with more vibes."
}

###

# Delete a movie
# Send request
DELETE {{api}}/5
Accept: application/json

###

# Try to delete non-existing movie
# Send request
DELETE {{api}}/8888
Accept: application/json

###

# Quick check after changes - first page again
# Send request
GET {{api}}?page=1&size=10
Accept: application/json

# ────────────────────────────────────────────────
# Useful tips for VS Code / Rider / IntelliJ HTTP Client:
#
#   • Click "Send Request" link that appears above each block
#   • Or use shortcut: Ctrl+Alt+R  (or Alt+Enter in some IDEs)
#   • Responses appear in a separate pane / tab
#   • You can chain requests using variables like:
#       @createdId = {{response body.$.id}}
# ────────────────────────────────────────────────


###
# Actors API - REST Client file
@actors = {{baseUrl}}/api/v1/actors

###

# List actors
GET {{actors}}?page=1&size=10
Accept: application/json

###

# Get one actor
GET {{actors}}/1
Accept: application/json

###

# Create a new actor
POST {{actors}}
Content-Type: application/json

{
  "name": "Leonardo DiCaprio"
}

###

# Create another actor
POST {{actors}}
Content-Type: application/json

{
  "name": "Tom Hardy"
}

###

# Update actor
PUT {{actors}}/1
Content-Type: application/json

{
  "name": "Leonardo Wilhelm DiCaprio"
}

###

# Delete actor
DELETE {{actors}}/2
Accept: application/json

###

# ────────────────────────────────────────────────
# Users API - REST Client file   ← added
# ────────────────────────────────────────────────

@users = {{baseUrl}}/api/v1/users

###

# List users - page 1
GET {{users}}?page=1&size=10
Accept: application/json

###

# List users - smaller page
GET {{users}}?page=1&size=5
Accept: application/json

###

# Get one user (from seed data)
GET {{users}}/1
Accept: application/json

###

# Get non-existing user
GET {{users}}/9999
Accept: application/json

###

# Create a new user (full)
POST {{users}}
Content-Type: application/json

{
  "username": "cinephile2025",
  "email": "movies@fan.com",
  "fullName": "Alex Cinema",
  "birthYear": 1997,
  "bio": "Watching everything from classics to new releases. 500+ films logged."
}

###

# Create another user (minimal - only required)
POST {{users}}
Content-Type: application/json

{
  "username": "quicktest",
  "email": "test.user@example.com"
}

###

# Update user (full body)
PUT {{users}}/1
Content-Type: application/json

{
  "username": "johndoe_updated",
  "email": "john.doe.updated@gmail.com",
  "fullName": "John Michael Doe",
  "birthYear": 1989,
  "bio": "Now also into anime and documentaries."
}

###

# Update only some fields
PUT {{users}}/2
Content-Type: application/json

{
  "bio": "Updated bio - more coffee, more movies, less sleep."
}

###

# Delete a user
DELETE {{users}}/3
Accept: application/json

###

# Try to delete non-existing user
DELETE {{users}}/7777
Accept: application/json

###

# Quick check after changes - first page again
GET {{users}}?page=1&size=10
Accept: application/json